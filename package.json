{
  "name": "@aslan/payment-node",
  "version": "0.2.0",
  "description": "Aslan Payment SDK for Node.js -- server-side payment integration",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "aslan",
    "payment",
    "node",
    "morocco",
    "mad",
    "checkout",
    "payment-gateway"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Belkouche/aslan-payment-node"
  }
}
